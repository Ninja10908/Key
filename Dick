local b = game:GetService("RunService")
local c = game:GetService("Players").LocalPlayer

local d = Instance.new("ScreenGui")
d.Name = "SpeedGui"
d.ResetOnSpawn = false
d.Parent = c:WaitForChild("PlayerGui")

local e = Instance.new("TextButton")
e.Name = "SpeedButton"
e.Text = "Speed"
e.Size = UDim2.new(0, 60, 0, 30)
e.Position = UDim2.new(1, -95, 0.5, -55)
e.AnchorPoint = Vector2.new(1, 0.5)
e.BackgroundColor3 = Color3.new(0, 0, 0)
e.TextColor3 = Color3.new(1, 1, 1)
e.Font = Enum.Font.GothamBold
e.TextSize = 14
e.Parent = d
Instance.new("UICorner", e).CornerRadius = UDim.new(0, 6)

local f = false
local speed = 100
local i, j, k
local l
local unequipConnection = nil
local toolCheckConnection = nil

local function unequipAllTools()
    local char = c.Character
    if not char then return end
    
    local hum = char:FindFirstChild("Humanoid")
    if hum then
        hum:UnequipTools()
    end
    
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            tool.Parent = c.Backpack
        end
    end
    
    for _, tool in ipairs(c.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            tool.Parent = c.Backpack
        end
    end
end

local function blockTools()
    if toolCheckConnection then
        toolCheckConnection:Disconnect()
    end
    
    toolCheckConnection = c.ChildAdded:Connect(function(child)
        if f and child:IsA("Tool") then
            child:Destroy()
        end
    end)
    
    local char = c.Character
    if char then
        local function checkTool(tool)
            if f and tool:IsA("Tool") then
                tool:Destroy()
            end
        end
        
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                checkTool(tool)
            end
        end
        
        char.ChildAdded:Connect(checkTool)
    end
end

local function allowTools()
    if toolCheckConnection then
        toolCheckConnection:Disconnect()
        toolCheckConnection = nil
    end
end

local function initChar()
    if not c.Character then
        c.CharacterAdded:Wait()
    end
    i = c.Character
    j = i:WaitForChild("Humanoid")
    k = i:WaitForChild("HumanoidRootPart")
end

local function setupSpeed()
    if l then
        l:Disconnect()
    end
    l = b.RenderStepped:Connect(function()
        if f and k and j then
            local moveDir = j.MoveDirection
            if moveDir.Magnitude > 0 then
                k.Velocity = Vector3.new(moveDir.X * speed, k.Velocity.Y, moveDir.Z * speed)
            end
        end
    end)
end

e.MouseButton1Click:Connect(function()
    f = not f
    e.BackgroundColor3 = f and Color3.new(0, 1, 0) or Color3.new(0, 0, 0)
    
    if f then
        initChar()
        unequipAllTools()
        blockTools()
        setupSpeed()
    else
        if l then
            l:Disconnect()
            l = nil
        end
        if j then
            j.WalkSpeed = 16
        end
        allowTools()
    end
end)

c.CharacterAdded:Connect(function(t)
    task.wait(0.5)
    i = t
    j = t:WaitForChild("Humanoid")
    k = t:WaitForChild("HumanoidRootPart")
    
    if f then
        unequipAllTools()
        blockTools()
        setupSpeed()
    end
end)

getfenv().shsp = function()
    if d then d:Destroy() end
    if l then l:Disconnect() end
    if toolCheckConnection then toolCheckConnection:Disconnect() end
    if unequipConnection then unequipConnection:Disconnect() end
    if j then j.WalkSpeed = 16 end
    allowTools()
end
